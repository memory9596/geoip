{
  "input": [
    {
      "type": "text",
      "action": "add",
      "args": {
        "name": "cn",
        "uri": "https://raw.githubusercontent.com/memory9596/clash_rule/release/geoip/cn.list"
      }
    }
  ],
  "output": [
    {
      "type": "v2rayGeoIPDat",
